QWidget {
    background: #f5f5f5;
    color: #111;
    font-size: 13px;
    font-family: Segoe UI;
}

QLineEdit,
QTextEdit {
    background: white;
    border: 1px solid #bbb;
    border-radius: 6px;
    padding: 6px;
}

QPushButton {
    background: #ddd;
    border: 1px solid #aaa;
    border-radius: 6px;
    padding: 8px;
}

QPushButton:hover {
    background: #ccc;
}

QPushButton:disabled {
    background: #eee;
    color: #888;
}

QTabWidget::pane {
    border: 1px solid #bbb;
}

QTabBar::tab {
    background: #ddd;
    padding: 10px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: white;
}

QStatusBar {
    background: #e9e9e9;
}