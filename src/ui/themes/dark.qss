QWidget {
    background: #1e1e1e;
    color: #f0f0f0;
    font-size: 13px;
    font-family: Segoe UI;
}

QLineEdit,
QTextEdit {
    background: #2a2a2a;
    border: 1px solid #444;
    border-radius: 6px;
    padding: 6px;
}

QPushButton {
    background: #3a3a3a;
    border: 1px solid #555;
    border-radius: 6px;
    padding: 8px;
}

QPushButton:hover {
    background: #4a4a4a;
}

QPushButton:disabled {
    background: #2b2b2b;
    color: #777;
}

QTabWidget::pane {
    border: 1px solid #444;
}

QTabBar::tab {
    background: #2d2d2d;
    padding: 10px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: #3d3d3d;
}

QStatusBar {
    background: #2a2a2a;
}