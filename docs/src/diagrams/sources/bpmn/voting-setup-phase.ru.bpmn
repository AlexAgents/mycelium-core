      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="fs3_di" bpmnElement="fs3">
        <di:waypoint x="960" y="480" />
        <di:waypoint x="1260" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="fs4_di" bpmnElement="fs4">
        <di:waypoint x="1380" y="480" />
        <di:waypoint x="1400" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="fs5_di" bpmnElement="fs5">
        <di:waypoint x="1520" y="480" />
        <di:waypoint x="1552" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF1_di" bpmnElement="MF1">
        <di:waypoint x="620" y="200" />
        <di:waypoint x="620" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="628" y="310" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF2_di" bpmnElement="MF2">
        <di:waypoint x="900" y="200" />
        <di:waypoint x="900" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="920" y="297" width="61" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF3_di" bpmnElement="MF3">
        <di:waypoint x="1320" y="200" />
        <di:waypoint x="1320" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1331" y="303" width="57" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MF4_di" bpmnElement="MF4">
        <di:waypoint x="1460" y="200" />
        <di:waypoint x="1460" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1496" y="310" width="67" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
