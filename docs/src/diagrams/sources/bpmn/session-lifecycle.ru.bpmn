<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_session" targetNamespace="http://mycelium.core/bpmn/session" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collab_session">
    <bpmn:participant id="Pool_Admin" name="Администратор" processRef="Proc_Admin" />
    <bpmn:participant id="Pool_System" name="System / Session Manager" processRef="Proc_System" />
    <bpmn:messageFlow id="MF_cmd" name="New Session command" sourceRef="T_A_Click" targetRef="T_S_Archive" />
    <bpmn:messageFlow id="Flow_18rkfex" name="UI reset confirmation" sourceRef="T_S_Reset" targetRef="EE_A">
      <bpmn:extensionElements />
    </bpmn:messageFlow>
  </bpmn:collaboration>
  <bpmn:process id="Proc_Admin" isExecutable="false">
    <bpmn:userTask id="T_A_Click" name="Нажать New Session" />
    <bpmn:exclusiveGateway id="GW_A" name="Выбор режима" />
    <bpmn:sequenceFlow id="fa1" sourceRef="SE_A" targetRef="T_A_Click" />
    <bpmn:sequenceFlow id="fa2" sourceRef="T_A_Click" targetRef="GW_A" />
    <bpmn:sequenceFlow id="fa3" name="Fast" sourceRef="GW_A" targetRef="T_A_Fast" />
    <bpmn:sequenceFlow id="fa4" name="Clean" sourceRef="GW_A" targetRef="T_A_Clean" />
    <bpmn:sequenceFlow id="fa5" sourceRef="T_A_Fast" targetRef="EE_A" />
    <bpmn:sequenceFlow id="fa6" sourceRef="T_A_Clean" targetRef="EE_A" />
    <bpmn:userTask id="T_A_Clean" name="Чистый режим&#10;(подтвердить сброс)" />
    <bpmn:endEvent id="EE_A" name="Новая сессия готова" />
    <bpmn:userTask id="T_A_Fast" name="Быстрый режим&#10;(оставить Geth)" />
    <bpmn:startEvent id="SE_A" name="Решение о сбросе" />
  </bpmn:process>
  <bpmn:process id="Proc_System" isExecutable="false">
    <bpmn:startEvent id="SE_S" name="Команда получена" />
    <bpmn:serviceTask id="T_S_Archive" name="Архивация логов&#10;в logs/archive/" />
    <bpmn:serviceTask id="T_S_Stop" name="Остановка Geth&#10;(taskkill)" />
    <bpmn:serviceTask id="T_S_Delete" name="Удаление&#10;chain-data/active/" />
    <bpmn:serviceTask id="T_S_Restart" name="Перезапуск Geth&#10;Ожидание RPC" />
    <bpmn:serviceTask id="T_S_CleanUUID" name="Новый UUID&#10;(чистый режим)" />
    <bpmn:serviceTask id="T_S_Reset" name="Сброс контекста&#10;MainWindow" />
    <bpmn:sequenceFlow id="fs1" sourceRef="SE_S" targetRef="T_S_Archive" />
    <bpmn:sequenceFlow id="fs2" sourceRef="T_S_Archive" targetRef="GW_S" />
    <bpmn:sequenceFlow id="fs3" name="Fast" sourceRef="GW_S" targetRef="T_S_FastUUID" />
    <bpmn:sequenceFlow id="fs4" name="Clean" sourceRef="GW_S" targetRef="T_S_Stop" />
    <bpmn:sequenceFlow id="fs5" sourceRef="T_S_Stop" targetRef="T_S_Delete" />
    <bpmn:sequenceFlow id="fs6" sourceRef="T_S_Delete" targetRef="T_S_Restart" />
    <bpmn:sequenceFlow id="fs7" sourceRef="T_S_Restart" targetRef="T_S_CleanUUID" />
    <bpmn:sequenceFlow id="fs8" sourceRef="T_S_FastUUID" targetRef="T_S_Reset" />
    <bpmn:sequenceFlow id="fs9" sourceRef="T_S_CleanUUID" targetRef="T_S_Reset" />
    <bpmn:sequenceFlow id="fs10" sourceRef="T_S_Reset" targetRef="EE_S" />
    <bpmn:endEvent id="EE_S" name="Сессия инициализирована" />
    <bpmn:serviceTask id="T_S_FastUUID" name="Новый UUID&#10;(быстрый режим)" />
    <bpmn:exclusiveGateway id="GW_S" name="Режим?" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_session">
    <bpmndi:BPMNPlane id="Plane_session" bpmnElement="Collab_session">
      <bpmndi:BPMNShape id="Pool_Admin_di" bpmnElement="Pool_Admin" isHorizontal="true">
