<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_mass" targetNamespace="http://mycelium.core/bpmn/mass" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collab_mass">
    <bpmn:participant id="Pool_Admin" name="Administrator (VoteTab)" processRef="Proc_Admin" />
    <bpmn:participant id="Pool_Worker" name="MassVoteWorker (Background Thread)" processRef="Proc_Worker" />
    <bpmn:messageFlow id="MF_start" name="Voter list + candidate list" sourceRef="T_A_Confirm" targetRef="T_W_Init" />
    <bpmn:messageFlow id="MF_result" name="Summary results" sourceRef="T_W_Summary" targetRef="T_A_Toast" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Admin" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1pqxrv9" />
    <bpmn:startEvent id="SE_A" name="Админ нажимает Mass Vote" />
    <bpmn:exclusiveGateway id="GW_Src" name="Источник?" />
    <bpmn:sequenceFlow id="fa1" sourceRef="SE_A" targetRef="GW_Src" />
    <bpmn:sequenceFlow id="fa2" name="JSON" sourceRef="GW_Src" targetRef="T_A_JSON" />
    <bpmn:sequenceFlow id="fa3" name="Session" sourceRef="GW_Src" targetRef="T_A_Session" />
    <bpmn:sequenceFlow id="fa4" sourceRef="T_A_JSON" targetRef="T_A_Confirm" />
    <bpmn:sequenceFlow id="fa5" sourceRef="T_A_Session" targetRef="T_A_Confirm" />
    <bpmn:sequenceFlow id="fa6" sourceRef="T_A_Confirm" targetRef="T_A_Toast" />
    <bpmn:sequenceFlow id="fa7" sourceRef="T_A_Toast" targetRef="EE_A" />
    <bpmn:endEvent id="EE_A" name="Массовое голосование завершено" />
    <bpmn:userTask id="T_A_Toast" name="Toast результатов&#10;(успех / пропуск / ошибка)" />
    <bpmn:userTask id="T_A_Confirm" name="Подтверждение&#10;(избиратели × кандидаты)" />
    <bpmn:userTask id="T_A_Session" name="Избиратели из&#10;текущей сессии" />
    <bpmn:userTask id="T_A_JSON" name="Выбрать JSON файл&#10;с избирателями" />
  </bpmn:process>
  <bpmn:process id="Proc_Worker" isExecutable="false">
    <bpmn:startEvent id="SE_W" name="Worker запущен" />
    <bpmn:serviceTask id="T_W_Init" name="Получение списков&#10;избирателей и кандидатов" />
    <bpmn:serviceTask id="T_W_Loop" name="Для каждого избирателя:" />
    <bpmn:exclusiveGateway id="GW_Key" name="Есть приватный ключ?" />
    <bpmn:serviceTask id="T_W_WL" name="Проверка whitelist" />
    <bpmn:exclusiveGateway id="GW_WL" name="В whitelist?" />
    <bpmn:serviceTask id="T_W_Voted" name="Проверка has_voted" />
    <bpmn:exclusiveGateway id="GW_Voted" name="Уже голосовал?" />
    <bpmn:serviceTask id="T_W_Balance" name="Проверка баланса&#10;≥ 0.0003 ETH" />
    <bpmn:exclusiveGateway id="GW_Bal" name="Достаточно?" />
    <bpmn:serviceTask id="T_W_Vote" name="cast_vote()&#10;(случайный кандидат)" />
    <bpmn:exclusiveGateway id="GW_TX" name="TX успешна?" />
    <bpmn:sequenceFlow id="fw1" sourceRef="SE_W" targetRef="T_W_Init" />
    <bpmn:sequenceFlow id="fw2" sourceRef="T_W_Init" targetRef="T_W_Loop" />
    <bpmn:sequenceFlow id="fw3" sourceRef="T_W_Loop" targetRef="GW_Key" />
    <bpmn:sequenceFlow id="fw4" name="Нет" sourceRef="GW_Key" targetRef="T_W_SkipKey" />
    <bpmn:sequenceFlow id="fw5" name="Да" sourceRef="GW_Key" targetRef="T_W_WL" />
    <bpmn:sequenceFlow id="fw6" sourceRef="T_W_WL" targetRef="GW_WL" />
    <bpmn:sequenceFlow id="fw7" name="Нет" sourceRef="GW_WL" targetRef="T_W_SkipWL" />
    <bpmn:sequenceFlow id="fw8" name="Да" sourceRef="GW_WL" targetRef="T_W_Voted" />
    <bpmn:sequenceFlow id="fw9" sourceRef="T_W_Voted" targetRef="GW_Voted" />
    <bpmn:sequenceFlow id="fw10" name="Да" sourceRef="GW_Voted" targetRef="T_W_SkipVoted" />
    <bpmn:sequenceFlow id="fw11" name="Нет" sourceRef="GW_Voted" targetRef="T_W_Balance" />
    <bpmn:sequenceFlow id="fw12" sourceRef="T_W_Balance" targetRef="GW_Bal" />
    <bpmn:sequenceFlow id="fw13" name="Нет" sourceRef="GW_Bal" targetRef="T_W_SkipBal" />
    <bpmn:sequenceFlow id="fw14" name="Да" sourceRef="GW_Bal" targetRef="T_W_Vote" />
    <bpmn:sequenceFlow id="fw15" sourceRef="T_W_Vote" targetRef="GW_TX" />
    <bpmn:sequenceFlow id="fw16" name="OK" sourceRef="GW_TX" targetRef="T_W_OK" />
    <bpmn:sequenceFlow id="fw17" name="Error" sourceRef="GW_TX" targetRef="T_W_Fail" />
    <bpmn:sequenceFlow id="fw18" sourceRef="T_W_OK" targetRef="T_W_Summary" />
    <bpmn:sequenceFlow id="fw20" sourceRef="T_W_SkipKey" targetRef="T_W_Summary" />
    <bpmn:sequenceFlow id="fw21" sourceRef="T_W_SkipWL" targetRef="T_W_Summary" />
    <bpmn:sequenceFlow id="fw23" sourceRef="T_W_SkipBal" targetRef="T_W_Summary" />
    <bpmn:sequenceFlow id="fw24" sourceRef="T_W_Summary" targetRef="EE_W" />
    <bpmn:sequenceFlow id="fw22" sourceRef="T_W_SkipVoted" targetRef="T_W_Summary" />
    <bpmn:sequenceFlow id="fw19" sourceRef="T_W_Fail" targetRef="T_W_Summary" />
    <bpmn:serviceTask id="T_W_Fail" name="failed++&#10;Логировать ошибку">
      <bpmn:outgoing>fw19</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_W_SkipBal" name="Пропуск: низкий баланс" />
    <bpmn:serviceTask id="T_W_SkipVoted" name="Пропуск: уже голосовал">
      <bpmn:outgoing>fw22</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_W_Summary" name="Сборка сводки&#10;{voted, skipped, failed}">
      <bpmn:incoming>fw22</bpmn:incoming>
      <bpmn:incoming>fw20</bpmn:incoming>
      <bpmn:incoming>fw19</bpmn:incoming>
      <bpmn:incoming>fw23</bpmn:incoming>
      <bpmn:incoming>fw18</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_W_SkipWL" name="Пропуск: не в WL" />
    <bpmn:serviceTask id="T_W_SkipKey" name="Пропуск: нет ключа" />
    <bpmn:serviceTask id="T_W_OK" name="voted++&#10;Логировать TX hash" />
    <bpmn:endEvent id="EE_W" name="finished.emit(summary)" />
  </bpmn:process>
