<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_cast" targetNamespace="http://mycelium.core/bpmn/cast" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collab_cast">
    <bpmn:participant id="Pool_Voter" name="Избиратель" processRef="Proc_Voter" />
    <bpmn:participant id="Pool_System" name="Система / Блокчейн" processRef="Proc_System" />
    <bpmn:messageFlow id="MF_tx" name="Signed castVote TX" sourceRef="T_V_Cast" targetRef="T_S_Precheck" />
    <bpmn:messageFlow id="MF_ok" name="TX Receipt + QR" sourceRef="T_S_Receipt" targetRef="T_V_QR" />
    <bpmn:messageFlow id="MF_fail" name="Сообщение Error" sourceRef="EE_S_Fail" targetRef="T_V_Error" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Voter" isExecutable="false">
    <bpmn:startEvent id="SE_V" name="Есть приватный ключ" />
    <bpmn:userTask id="T_V_Key" name="Ввод приватного ключа&#10;(или Загрузка JSON)" />
    <bpmn:userTask id="T_V_LoadCand" name="Загрузка кандидатов&#10;из блокчейна" />
    <bpmn:userTask id="T_V_Select" name="Выбор кандидата&#10;(radio button)" />
    <bpmn:userTask id="T_V_Cast" name="Нажать CAST VOTE" />
    <bpmn:exclusiveGateway id="GW_V" name="TX успешна?" />
    <bpmn:sequenceFlow id="fv1" sourceRef="SE_V" targetRef="T_V_Key" />
    <bpmn:sequenceFlow id="fv2" sourceRef="T_V_Key" targetRef="T_V_LoadCand" />
    <bpmn:sequenceFlow id="fv3" sourceRef="T_V_LoadCand" targetRef="T_V_Select" />
    <bpmn:sequenceFlow id="fv4" sourceRef="T_V_Select" targetRef="T_V_Cast" />
    <bpmn:sequenceFlow id="fv5" sourceRef="T_V_Cast" targetRef="GW_V" />
    <bpmn:sequenceFlow id="fv6" name="Да" sourceRef="GW_V" targetRef="T_V_QR" />
    <bpmn:sequenceFlow id="fv7" name="Нет" sourceRef="GW_V" targetRef="T_V_Error" />
    <bpmn:sequenceFlow id="fv8" sourceRef="T_V_QR" targetRef="EE_V_OK" />
    <bpmn:sequenceFlow id="fv9" sourceRef="T_V_Error" targetRef="EE_V_Fail" />
    <bpmn:userTask id="T_V_QR" name="Просмотр TX Hash&#10;и QR-квитанции" />
    <bpmn:userTask id="T_V_Error" name="Диалог с ошибкой&#10;(локализованный)" />
    <bpmn:endEvent id="EE_V_Fail" name="Голос отклонён" />
    <bpmn:endEvent id="EE_V_OK" name="Голос записан" />
  </bpmn:process>
  <bpmn:process id="Proc_System" isExecutable="false">
    <bpmn:startEvent id="SE_S" name="TX получена" />
    <bpmn:serviceTask id="T_S_Precheck" name="5-уровневый precheck&#10;(ключ, контракт, WL,&#10;голос, баланс)" />
    <bpmn:exclusiveGateway id="GW_S" name="Precheck пройден?" />
    <bpmn:serviceTask id="T_S_Sign" name="Подпись TX&#10;(NonceManager)" />
    <bpmn:serviceTask id="T_S_Broadcast" name="Отправка в Geth&#10;(send_raw_transaction)" />
    <bpmn:serviceTask id="T_S_Wait" name="Ожидание квитанции&#10;(таймаут 120с)" />
    <bpmn:serviceTask id="T_S_Receipt" name="Генерация VoteReceipt&#10;и QR-кода" />
    <bpmn:endEvent id="EE_S_OK" name="VoteCast event emitted" />
    <bpmn:sequenceFlow id="fs1" sourceRef="SE_S" targetRef="T_S_Precheck" />
    <bpmn:sequenceFlow id="fs2" sourceRef="T_S_Precheck" targetRef="GW_S" />
    <bpmn:sequenceFlow id="fs3" name="Да" sourceRef="GW_S" targetRef="T_S_Sign" />
    <bpmn:sequenceFlow id="fs4" name="Нет" sourceRef="GW_S" targetRef="EE_S_Fail" />
    <bpmn:sequenceFlow id="fs5" sourceRef="T_S_Sign" targetRef="T_S_Broadcast" />
    <bpmn:sequenceFlow id="fs6" sourceRef="T_S_Broadcast" targetRef="T_S_Wait" />
    <bpmn:sequenceFlow id="fs7" sourceRef="T_S_Wait" targetRef="T_S_Receipt" />
    <bpmn:sequenceFlow id="fs8" sourceRef="T_S_Receipt" targetRef="EE_S_OK" />
    <bpmn:endEvent id="EE_S_Fail" name="Ошибка" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_cast">
    <bpmndi:BPMNPlane id="Plane_cast" bpmnElement="Collab_cast">
      <bpmndi:BPMNShape id="Pool_Voter_di" bpmnElement="Pool_Voter" isHorizontal="true">
        <dc:Bounds x="160" y="60" width="1200" height="220" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SE_V_di" bpmnElement="SE_V">
        <dc:Bounds x="210" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="199" y="196" width="82" height="27" />
        </bpmndi:BPMNLabel>
