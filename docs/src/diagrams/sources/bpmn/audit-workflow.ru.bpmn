<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_audit" targetNamespace="http://mycelium.core/bpmn/audit" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collab_audit">
    <bpmn:participant id="Pool_Auditor" name="Аудитор" processRef="Proc_Auditor" />
    <bpmn:participant id="Pool_System" name="System / AuditService" processRef="Proc_System" />
    <bpmn:messageFlow id="MF_run" name="Run Audit запрос" sourceRef="T_Au_Run" targetRef="T_S_Query" />
    <bpmn:messageFlow id="MF_res" name="Проверка результатов" sourceRef="T_S_Format" targetRef="T_Au_Review" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_Auditor" isExecutable="false">
    <bpmn:startEvent id="SE_Au" name="Аудитор открывает вкладку Audit" />
    <bpmn:userTask id="T_Au_Mode" name="Выбор режима аудита&#10;(Full / Pre / Live / Final)" />
    <bpmn:userTask id="T_Au_Run" name="Нажать Run Audit" />
    <bpmn:userTask id="T_Au_Review" name="Проверка таблицы&#10;результатов SEC" />
    <bpmn:sequenceFlow id="fau1" sourceRef="SE_Au" targetRef="T_Au_Mode" />
    <bpmn:sequenceFlow id="fau2" sourceRef="T_Au_Mode" targetRef="T_Au_Run" />
    <bpmn:sequenceFlow id="fau3" sourceRef="T_Au_Run" targetRef="T_Au_Review" />
    <bpmn:sequenceFlow id="fau4" sourceRef="T_Au_Review" targetRef="GW_Au" />
    <bpmn:userTask id="T_Au_Copy" name="Копировать отчёт" />
    <bpmn:userTask id="T_Au_JSON" name="Экспорт в JSON" />
    <bpmn:userTask id="T_Au_CSV" name="Экспорт в CSV" />
    <bpmn:endEvent id="EE_Au" name="Отчёт сохранен" />
    <bpmn:exclusiveGateway id="GW_Au" name="Все пройдено?" />
    <bpmn:sequenceFlow id="fau5" name="Да" sourceRef="GW_Au" targetRef="T_Au_Copy" />
    <bpmn:sequenceFlow id="fau7" sourceRef="T_Au_Copy" targetRef="T_Au_JSON" />
    <bpmn:sequenceFlow id="fau8" sourceRef="T_Au_JSON" targetRef="T_Au_CSV" />
    <bpmn:sequenceFlow id="fau9" sourceRef="T_Au_CSV" targetRef="EE_Au" />
    <bpmn:sequenceFlow id="fau6" name="Нет" sourceRef="GW_Au" targetRef="T_Au_Invest" />
    <bpmn:sequenceFlow id="fau10" sourceRef="T_Au_Invest" targetRef="EE_Au" />
    <bpmn:userTask id="T_Au_Invest" name="Анализ ошибок&#10;и логов" />
  </bpmn:process>
  <bpmn:process id="Proc_System" isExecutable="false">
    <bpmn:sequenceFlow id="fs1" sourceRef="SE_S" targetRef="T_S_Query" />
    <bpmn:startEvent id="SE_S" name="Запрос получен" />
    <bpmn:serviceTask id="T_S_Query" name="Запрос событий&#10;VoteCast, StageChanged" />
    <bpmn:serviceTask id="T_S_SEC01" name="SEC-01&#10;Double Vote" />
    <bpmn:serviceTask id="T_S_SEC02" name="SEC-02&#10;Whitelist" />
    <bpmn:serviceTask id="T_S_SEC03" name="SEC-03&#10;Stage" />
    <bpmn:serviceTask id="T_S_SEC04" name="SEC-04&#10;Candidates" />
    <bpmn:serviceTask id="T_S_SEC05" name="SEC-05&#10;Owner" />
    <bpmn:serviceTask id="T_S_SEC06" name="SEC-06&#10;Integrity" />
    <bpmn:serviceTask id="T_S_Compile" name="Сборка&#10;AuditReport" />
    <bpmn:serviceTask id="T_S_Format" name="Формати-рование&#10;JSON / CSV">
      <bpmn:extensionElements />
    </bpmn:serviceTask>
    <bpmn:endEvent id="EE_S" name="Результаты возвращены" />
    <bpmn:sequenceFlow id="fs2" sourceRef="T_S_Query" targetRef="T_S_SEC01" />
    <bpmn:sequenceFlow id="fs3" sourceRef="T_S_SEC01" targetRef="T_S_SEC02" />
    <bpmn:sequenceFlow id="fs4" sourceRef="T_S_SEC02" targetRef="T_S_SEC03" />
    <bpmn:sequenceFlow id="fs5" sourceRef="T_S_SEC03" targetRef="T_S_SEC04" />
    <bpmn:sequenceFlow id="fs6" sourceRef="T_S_SEC04" targetRef="T_S_SEC05" />
    <bpmn:sequenceFlow id="fs7" sourceRef="T_S_SEC05" targetRef="T_S_SEC06" />
    <bpmn:sequenceFlow id="fs8" sourceRef="T_S_SEC06" targetRef="T_S_Compile" />
    <bpmn:sequenceFlow id="fs9" sourceRef="T_S_Compile" targetRef="T_S_Format" />
    <bpmn:sequenceFlow id="fs10" sourceRef="T_S_Format" targetRef="EE_S" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_audit">
    <bpmndi:BPMNPlane id="Plane_audit" bpmnElement="Collab_audit">
      <bpmndi:BPMNShape id="Pool_Auditor_di" bpmnElement="Pool_Auditor" isHorizontal="true">
