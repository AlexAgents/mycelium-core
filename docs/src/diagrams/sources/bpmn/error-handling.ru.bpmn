<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_error" targetNamespace="http://mycelium.core/bpmn/error" exporter="Camunda Modeler" exporterVersion="5.46.1">
  <bpmn:collaboration id="Collab_error">
    <bpmn:participant id="Pool_UI" name="UI Layer (PyQt6)" processRef="Proc_UI" />
    <bpmn:participant id="Pool_Core" name="Core Layer (AppController + Services)" processRef="Proc_Core" />
    <bpmn:messageFlow id="MF_action" name="User action" sourceRef="T_UI_Action" targetRef="T_C_Execute" />
    <bpmn:messageFlow id="MF_parsed" name="ParsedError (i18n keys)" sourceRef="T_C_Parse" targetRef="T_UI_Dialog" />
    <bpmn:messageFlow id="MF_success" name="Success result" sourceRef="T_C_Execute" targetRef="T_UI_Toast" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_UI" isExecutable="false">
    <bpmn:startEvent id="SE_UI" name="Пользователь нажимает кнопку" />
    <bpmn:userTask id="T_UI_Action" name="Запуск операции&#10;(деплой / голос / fund / whitelist)" />
    <bpmn:exclusiveGateway id="GW_UI" name="Результат?" />
    <bpmn:userTask id="T_UI_Toast" name="Toast успеха&#10;(зелёное уведомление)" />
    <bpmn:sequenceFlow id="fu1" sourceRef="SE_UI" targetRef="T_UI_Action" />
    <bpmn:sequenceFlow id="fu2" sourceRef="T_UI_Action" targetRef="GW_UI" />
    <bpmn:sequenceFlow id="fu3" name="Success" sourceRef="GW_UI" targetRef="T_UI_Toast" />
    <bpmn:sequenceFlow id="fu4" name="Error" sourceRef="GW_UI" targetRef="T_UI_Dialog" />
    <bpmn:sequenceFlow id="fu5" sourceRef="T_UI_Toast" targetRef="EE_UI_OK" />
    <bpmn:sequenceFlow id="fu6" sourceRef="T_UI_Dialog" targetRef="GW_Action" />
    <bpmn:sequenceFlow id="fu7" name="Да" sourceRef="GW_Action" targetRef="T_UI_DoAction" />
    <bpmn:sequenceFlow id="fu8" name="Нет" sourceRef="GW_Action" targetRef="EE_UI_Dismiss" />
    <bpmn:sequenceFlow id="fu9" sourceRef="T_UI_DoAction" targetRef="EE_UI_OK" />
    <bpmn:userTask id="T_UI_Dialog" name="ErrorDialog&#10;(перевод сообщения&#10;+ кнопка действия)" />
    <bpmn:endEvent id="EE_UI_OK" name="Операция завершена" />
    <bpmn:endEvent id="EE_UI_Dismiss" name="Пользователь закрыл ошибку" />
    <bpmn:userTask id="T_UI_DoAction" name="Предложенное действие&#10;(напр. Пополнить счет,&#10;Синхр. nonce)" />
    <bpmn:exclusiveGateway id="GW_Action" name="Нажата кнопка?" />
  </bpmn:process>
  <bpmn:process id="Proc_Core" isExecutable="false">
    <bpmn:startEvent id="SE_C" name="Запрос получен" />
    <bpmn:serviceTask id="T_C_Execute" name="Операция блокчейна&#10;через VotingService" />
    <bpmn:serviceTask id="T_C_Return" name="Возврат успеха&#10;(VoteReceipt / TX hash)" />
    <bpmn:serviceTask id="T_C_Catch" name="Перехват исключения&#10;(ContractLogic /&#10;Value / Timeout)" />
    <bpmn:serviceTask id="T_C_Parse" name="ErrorParser.parse()&#10;→ ParsedError&#10;{message_key, action_key,&#10;action_id}" />
    <bpmn:serviceTask id="T_C_Humanize" name="_humanize_contract_error()&#10;(NotWhitelisted →&#10;понятный текст)" />
    <bpmn:endEvent id="EE_C_OK" name="Успех" />
    <bpmn:endEvent id="EE_C_Err" name="Ошибка" />
    <bpmn:sequenceFlow id="fc1" sourceRef="SE_C" targetRef="T_C_Execute" />
    <bpmn:sequenceFlow id="fc2" sourceRef="T_C_Execute" targetRef="GW_C" />
    <bpmn:sequenceFlow id="fc3" name="OK" sourceRef="GW_C" targetRef="T_C_Return" />
    <bpmn:sequenceFlow id="fc4" name="Исключение" sourceRef="GW_C" targetRef="T_C_Catch" />
    <bpmn:sequenceFlow id="fc5" sourceRef="T_C_Return" targetRef="EE_C_OK" />
    <bpmn:sequenceFlow id="fc6" sourceRef="T_C_Catch" targetRef="T_C_Humanize" />
    <bpmn:sequenceFlow id="fc7" sourceRef="T_C_Humanize" targetRef="T_C_Parse" />
    <bpmn:sequenceFlow id="fc8" sourceRef="T_C_Parse" targetRef="EE_C_Err" />
    <bpmn:exclusiveGateway id="GW_C" name="Результат TX?" />
  </bpmn:process>
