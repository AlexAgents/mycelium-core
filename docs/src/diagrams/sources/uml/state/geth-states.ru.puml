@startuml
!include ../_common/theme.iuml

title Диаграмма состояний: Состояния GethManager

[*] --> Остановлен

state Остановлен {
    Остановлен : - _process равен None
    Остановлен : - порт 8545 свободен
}

Остановлен --> Запускается : start() [создает процесс geth]

state Запускается {
    Запускается : - process.poll() равен None
    Запускается : - период ожидания RPC (5с)
}

Запускается --> Работает : wait_for_rpc() успех
Запускается --> Упал : процесс завершился во время ожидания

state Работает {
    Работает : - RPC готов (блок >= 0)
    Работает : - MonitorThread активен
}

Работает --> Упал : процесс завершился неожиданно
Работает --> Остановлен : stop() [shutting_down = True]
Упал --> Остановлен : stop() [пользователь подтвердил]

@enduml