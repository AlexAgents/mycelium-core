@startuml
!include ../_common/theme.iuml

title Диаграмма последовательности: Массовое голосование

actor "Администратор" as Admin
participant "Вкладка Vote" as UI
participant "MassVoteWorker" as Worker
participant "AppController" as AC
participant "VotingService" as VS
participant "Web3Provider" as WP

Admin -> UI : нажимает "Из сессии" / "Из JSON"
activate UI
UI -> UI : _check_stage_for_voting()
UI -> Worker : create(voters_list, candidates_list)
UI -> Worker : start()
activate Worker

loop для каждого избирателя в списке
  Worker -> AC : precheck_vote(voter.key)
  activate AC
  AC --> Worker : возвращает PrecheckResult
  deactivate AC

  alt precheck успешен
    Worker -> AC : cast_vote(private_key, candidate)
    activate AC
    AC -> VS : cast_vote()
    activate VS
    VS -> WP : send_transaction()
    activate WP
    WP --> VS : tx_hash
    deactivate WP
    VS --> AC : receipt
    deactivate VS
    AC --> Worker : успех
    deactivate AC
  else precheck не пройден
    note over Worker : Пропускает избирателя,\nлогирует причину
  end
end

Worker --> UI : finished.emit(summary_results)
deactivate Worker

UI -> UI : show Toast(voted_count, skipped_count)
UI --> Admin : отрисовывает лог результатов
deactivate UI

@enduml