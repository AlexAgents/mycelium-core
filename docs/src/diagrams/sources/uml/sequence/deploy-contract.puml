@startuml
!include ../_common/theme.iuml

title Sequence Diagram - Deploy VotingCore Contract

actor "Administrator" as Admin
participant "AdminTab" as UI
participant "DeployWorker" as Worker
participant "AppController" as AC
participant "CompilerService" as CS
participant "VotingService" as VS
participant "Web3Provider" as WP

Admin -> UI : click "Deploy"
activate UI
UI -> UI : validate_private_key()
UI -> Worker : create(admin_key)
UI -> Worker : start()
activate Worker

Worker -> AC : compile_contract()
activate AC
AC -> CS : compile_contract()
activate CS
note over CS : Compiles contract\nvia py-solc-x
CS --> AC : returns (abi, bytecode)
deactivate CS
AC --> Worker : returns (abi, bytecode)
deactivate AC

Worker -> AC : deploy_contract()
activate AC
AC -> VS : deploy_contract(abi, bytecode)
activate VS
VS -> WP : send_transaction(tx_data)
activate WP
note over WP : Broadcasts TX\nto local Geth
WP --> VS : returns tx_hash
deactivate WP
VS -> WP : wait_for_receipt(tx_hash)
activate WP
WP --> VS : returns receipt (contract_address)
deactivate WP
VS --> AC : returns contract_address
deactivate VS
AC -> AC : update SessionContext
AC --> Worker : returns contract_address
deactivate AC

Worker --> UI : finished.emit(contract_address)
deactivate Worker
UI -> UI : lock_inputs()
UI -> UI : show Toast("Success")
UI --> Admin : renders deployed state
deactivate UI

@enduml