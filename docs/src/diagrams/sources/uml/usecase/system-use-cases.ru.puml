@startuml
!include ../_common/theme.iuml

title Диаграмма вариантов использования — MYCELIUM CORE

left to right direction

actor "Администратор" as ADMIN
actor "Избиратель" as VOTER
actor "Аудитор" as AUDITOR

rectangle "MYCELIUM CORE" {

  ' ── Administrator Use Cases ──
  usecase "Деплой контракта VotingCore" as UC_DEPLOY
  usecase "Регистрация кандидатов" as UC_CAND
  usecase "Генерация тестовых избирателей" as UC_GEN
  usecase "Импорт / Экспорт избирателей JSON" as UC_IO
  usecase "Финансирование избирателей (ETH)" as UC_FUND
  usecase "Добавление в Whitelist" as UC_WL
  usecase "Начать голосование" as UC_START
  usecase "Завершить голосование" as UC_FINISH
  usecase "Создать новую сессию" as UC_SESSION
  usecase "Сбросить данные блокчейна" as UC_RESET

  ' ── Voter Use Cases ──
  usecase "Аутентификация по ключу" as UC_AUTH
  usecase "Подача голоса" as UC_VOTE
  usecase "Получение QR-квитанции" as UC_QR
  usecase "Массовое голосование (Тест)" as UC_MASS

  ' ── Auditor Use Cases ──
  usecase "Запуск аудита безопасности" as UC_AUDIT
  usecase "Просмотр результатов" as UC_RESULTS
  usecase "Экспорт отчета аудита" as UC_EXPORT

  ' ── Admin connections ──
  ADMIN --> UC_DEPLOY
  ADMIN --> UC_CAND
  ADMIN --> UC_GEN
  ADMIN --> UC_IO
  ADMIN --> UC_FUND
  ADMIN --> UC_WL
  ADMIN --> UC_START
  ADMIN --> UC_FINISH
  ADMIN --> UC_SESSION
  ADMIN --> UC_RESET

  ' ── Voter connections ──
  VOTER --> UC_AUTH
  VOTER --> UC_VOTE
  VOTER --> UC_QR
  VOTER --> UC_MASS

  ' ── Auditor connections ──
  AUDITOR --> UC_AUDIT
  AUDITOR --> UC_RESULTS
  AUDITOR --> UC_EXPORT

  ' ── Dependencies ──
  UC_VOTE ..> UC_AUTH : <<include>>
  UC_VOTE ..> UC_QR : <<include>>
  UC_MASS ..> UC_VOTE : <<include>>
  UC_AUDIT ..> UC_RESULTS : <<include>>
}

@enduml