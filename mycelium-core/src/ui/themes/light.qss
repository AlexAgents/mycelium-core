/* =================================================================
   MYCELIUM CORE -- Light Theme
================================================================= */

/* -- Base -------------------------------------------------------- */
QMainWindow { background-color: #f4f7fb; }
QWidget {
    background-color: #f4f7fb;
    color: #1f3a68;
    font-family: "Segoe UI", "Ubuntu", sans-serif;
    font-size: 13px;
}

/* -- Header ------------------------------------------------------ */
QWidget#headerBar {
    background-color: #e7eef7;
}
QLabel#headerTitle {
    font-size: 14px; font-weight: bold;
    color: #0969da; letter-spacing: 2px;
    background: transparent;
}
QFrame#headerSep { background: #c4d3e8; border: none; }

/* -- Group Boxes ------------------------------------------------- */
QGroupBox {
    border: 1px solid #c4d3e8;
    border-radius: 6px;
    margin-top: 14px;
    padding: 18px 12px 12px 12px;
    background-color: #ffffff;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 8px;
    color: #0969da;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    background-color: #f4f7fb;
}
QGroupBox[dragOver="true"] { border: 2px dashed #0969da; }

/* -- Inputs ------------------------------------------------------ */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 7px 10px;
    color: #1f3a68;
    selection-background-color: #0969da;
    selection-color: #ffffff;
    min-height: 20px;
}
QLineEdit:focus { border-color: #0969da; }
QLineEdit:disabled {
    color: #7286a5;
    background-color: #f4f7fb;
    border-color: #c4d3e8;
}
QLineEdit[readOnly="true"] {
    color: #3d5a80;
    background-color: #f4f7fb;
}

QSpinBox, QDoubleSpinBox {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 6px 8px;
    color: #1f3a68;
    min-height: 20px;
}
QSpinBox:focus, QDoubleSpinBox:focus { border-color: #0969da; }
QSpinBox::up-button, QSpinBox::down-button,
QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    background-color: #e7eef7;
    border: none;
    width: 20px;
}
QSpinBox::up-button:hover, QSpinBox::down-button:hover,
QDoubleSpinBox::up-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #c4d3e8;
}

QComboBox {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 5px 8px;
    color: #1f3a68;
    min-height: 20px;
}
QComboBox:focus { border-color: #0969da; }
QComboBox::drop-down {
    border: none;
    background: #e7eef7;
    width: 24px;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    color: #1f3a68;
    selection-background-color: #0969da;
    selection-color: #ffffff;
}

/* -- Buttons ----------------------------------------------------- */
QPushButton {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 5px;
    padding: 7px 16px;
    color: #1f3a68;
    font-weight: 500;
    min-height: 30px;
}
QPushButton:hover {
    background-color: #e7eef7;
    border-color: #0969da;
    color: #0969da;
}
QPushButton:pressed { background-color: #d6e2f0; }
QPushButton:disabled {
    color: #7286a5;
    border-color: #e7eef7;
    background-color: #f4f7fb;
}

QPushButton#deployButton {
    background-color: #0969da;
    border-color: #0969da;
    color: #ffffff;
    font-weight: bold;
}
QPushButton#deployButton:hover { background-color: #0860ca; }
QPushButton#deployButton:disabled {
    background-color: #f4f7fb;
    border-color: #c4d3e8;
    color: #7286a5;
}

QPushButton#registerCandidatesButton {
    background-color: #dbeafe;
    border-color: #0969da;
    color: #0550ae;
    font-weight: bold;
}
QPushButton#registerCandidatesButton:hover {
    background-color: #0969da;
    color: #ffffff;
}

QPushButton#whitelistButton {
    background-color: #dcfce7;
    border-color: #1a7f37;
    color: #116329;
    font-weight: bold;
}
QPushButton#whitelistButton:hover {
    background-color: #1a7f37;
    color: #ffffff;
}

QPushButton#startButton {
    background-color: #dcfce7;
    border-color: #1a7f37;
    color: #116329;
    font-weight: bold;
    min-height: 36px;
}
QPushButton#startButton:hover {
    background-color: #1a7f37;
    color: #ffffff;
}
QPushButton#startButton:disabled {
    background-color: #f4f7fb;
    border-color: #c4d3e8;
    color: #7286a5;
}

QPushButton#finishButton {
    background-color: #fef3e7;
    border-color: #bf6a02;
    color: #8a4b00;
    font-weight: bold;
    min-height: 36px;
}
QPushButton#finishButton:hover {
    background-color: #bf6a02;
    color: #ffffff;
}
QPushButton#finishButton:disabled {
    background-color: #f4f7fb;
    border-color: #c4d3e8;
    color: #7286a5;
}

QPushButton#castVoteButton {
    background-color: #1a7f37;
    border-color: #1a7f37;
    color: #ffffff;
    font-size: 15px;
    font-weight: bold;
    min-height: 46px;
    border-radius: 6px;
    letter-spacing: 1px;
}
QPushButton#castVoteButton:hover { background-color: #176f30; }
QPushButton#castVoteButton:disabled {
    background-color: #f4f7fb;
    border-color: #c4d3e8;
    color: #7286a5;
}

QPushButton#showHideButton {
    background-color: transparent;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 7px 10px;
    color: #3d5a80;
    min-width: 36px;
    min-height: 30px;
}
QPushButton#showHideButton:hover {
    color: #0969da;
    background-color: #e7eef7;
    border-color: #0969da;
}

QPushButton#iconButton {
    background-color: transparent;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 6px 10px;
    color: #3d5a80;
    min-width: 32px;
    min-height: 30px;
}
QPushButton#iconButton:hover {
    background-color: #e7eef7;
    color: #0969da;
    border-color: #0969da;
}

/* -- Tabs -------------------------------------------------------- */
QTabWidget::pane {
    border: none;
    background-color: #f4f7fb;
    top: 0;
}
QTabBar { background-color: #e7eef7; }
QTabBar::tab {
    background-color: #e7eef7;
    border: 1px solid #c4d3e8;
    border-bottom: none;
    padding: 9px 26px;
    color: #3d5a80;
    font-weight: 500;
    min-width: 80px;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background-color: #ffffff;
    color: #0969da;
    border-top: 2px solid #0969da;
}
QTabBar::tab:hover:!selected {
    background-color: #d6e2f0;
    color: #1f3a68;
}

/* -- Table ------------------------------------------------------- */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    gridline-color: #e7eef7;
    color: #1f3a68;
    alternate-background-color: #f4f7fb;
    selection-background-color: transparent;
    selection-color: #1f3a68;
    outline: none;
}
QTableWidget::item { padding: 6px 10px; border: none; }
QTableWidget::item:selected {
    background-color: rgba(9, 105, 218, 0.15);
    color: #1f3a68;
}
QHeaderView { background-color: #e7eef7; }
QHeaderView::section {
    background-color: #e7eef7;
    border: none;
    border-right: 1px solid #c4d3e8;
    border-bottom: 1px solid #c4d3e8;
    padding: 7px 10px;
    color: #3d5a80;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 1px;
}
QHeaderView::section:last { border-right: none; }
QTableWidget QTableCornerButton::section {
    background-color: #e7eef7;
    border-right: 1px solid #c4d3e8;
    border-bottom: 1px solid #c4d3e8;
}

/* -- Text areas -------------------------------------------------- */
QTextEdit {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    color: #1f3a68;
    font-family: "Consolas", "Courier New", monospace;
    font-size: 12px;
    padding: 8px;
    selection-background-color: #0969da;
    selection-color: #ffffff;
}
QTextEdit#logBox {
    background-color: #f4f7fb;
    border: 1px solid #e7eef7;
    color: #3d5a80;
    font-family: "Consolas", "Courier New", monospace;
    font-size: 11px;
}

/* -- Scroll bars ------------------------------------------------- */
QScrollBar:vertical {
    background-color: #f4f7fb;
    width: 8px; border: none;
}
QScrollBar::handle:vertical {
    background-color: #c4d3e8;
    border-radius: 4px; min-height: 20px;
}
QScrollBar::handle:vertical:hover { background-color: #7286a5; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal {
    background-color: #f4f7fb;
    height: 8px; border: none;
}
QScrollBar::handle:horizontal {
    background-color: #c4d3e8;
    border-radius: 4px; min-width: 20px;
}
QScrollBar::handle:horizontal:hover { background-color: #7286a5; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

QScrollArea { border: none; background-color: transparent; }
QScrollArea > QWidget > QWidget { background-color: #f4f7fb; }

/* -- Status bar -------------------------------------------------- */
QStatusBar {
    background-color: #e7eef7;
    border-top: 1px solid #c4d3e8;
    color: #3d5a80;
    font-size: 12px;
    padding: 2px 8px;
}
QStatusBar::item { border: none; padding: 0 4px; }

/* -- Labels ------------------------------------------------------ */
QLabel { color: #1f3a68; background-color: transparent; }
QLabel#fieldLabel {
    color: #3d5a80;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 1px;
    background: transparent;
}
QLabel#monoLabel {
    font-family: "Consolas", "Courier New", monospace;
    color: #0969da;
    font-size: 12px;
    background-color: #f4f7fb;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 6px 10px;
}
QLabel#statusValue {
    font-weight: bold;
    font-size: 13px;
    color: #1f3a68;
    background: transparent;
}
QLabel#sectionHeader {
    font-size: 13px;
    font-weight: bold;
    color: #1f3a68;
    padding: 4px 0;
    background: transparent;
}

/* -- Radio buttons ----------------------------------------------- */
QRadioButton {
    color: #1f3a68;
    spacing: 10px;
    padding: 8px 12px;
    border-radius: 4px;
    background-color: transparent;
}
QRadioButton:hover { background-color: #e7eef7; }
QRadioButton::indicator {
    width: 16px; height: 16px;
    border: 2px solid #7286a5;
    border-radius: 8px;
    background-color: #ffffff;
}
QRadioButton::indicator:checked {
    background-color: #1a7f37;
    border-color: #1a7f37;
}
QRadioButton::indicator:hover { border-color: #0969da; }

/* -- Tooltips ---------------------------------------------------- */
QToolTip {
    background-color: #1f3a68;
    border: 1px solid #0969da;
    color: #ffffff;
    padding: 4px 8px;
    border-radius: 4px;
}

/* -- Message boxes ----------------------------------------------- */
QMessageBox { background-color: #ffffff; }
QMessageBox QLabel { color: #1f3a68; background-color: transparent; }
QMessageBox QPushButton {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    color: #1f3a68;
    min-width: 80px;
    padding: 6px 14px;
}
QMessageBox QPushButton:hover {
    background-color: #e7eef7;
    border-color: #0969da;
    color: #0969da;
}

/* -- Frames ------------------------------------------------------ */
QFrame[frameShape="4"], QFrame[frameShape="5"] { color: #c4d3e8; }

/* -- Progress bar ------------------------------------------------ */
QProgressBar, QProgressBar#mainProgressBar {
    background-color: #e7eef7;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    height: 14px;
    color: #1f3a68;
    font-size: 10px;
    text-align: center;
}
QProgressBar::chunk, QProgressBar#mainProgressBar::chunk {
    border-radius: 3px;
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #0550ae,
        stop:0.5 #0969da,
        stop:1.0 #54aeff
    );
}

/* -- Checkbox ---------------------------------------------------- */
QCheckBox { color: #1f3a68; spacing: 8px; background: transparent; }
QCheckBox::indicator {
    width: 16px; height: 16px;
    border: 2px solid #7286a5;
    border-radius: 3px;
    background: #ffffff;
}
QCheckBox::indicator:checked {
    background-color: #0969da;
    border-color: #0969da;
}

/* -- Menu -------------------------------------------------------- */
QMenu {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    padding: 4px;
}
QMenu::item {
    padding: 6px 16px;
    color: #1f3a68;
    border-radius: 3px;
}
QMenu::item:selected {
    background-color: #0969da;
    color: #ffffff;
}

/* -- About dialog ------------------------------------------------ */
QLabel#aboutTitle { color: #0969da; background: transparent; }
QLabel#aboutVersion { color: #3d5a80; background: transparent; }
QLabel#aboutBody { color: #1f3a68; background: transparent; }

/* -- Logs tab ---------------------------------------------------- */
QLabel#logsTitle {
    color: #0969da;
    font-size: 14px;
    font-weight: bold;
    background: transparent;
}
QLabel#logsPathLabel {
    font-family: Consolas, monospace;
    color: #7286a5;
    font-size: 11px;
    background: transparent;
}
QLabel#logsCountLabel {
    color: #7286a5;
    font-size: 11px;
    background: transparent;
}
QTextEdit#logsViewer {
    background-color: #ffffff;
    border: 1px solid #c4d3e8;
    border-radius: 4px;
    color: #1f3a68;
    font-family: Consolas, "Courier New", monospace;
    font-size: 11px;
    padding: 8px;
}

/* -- Message dialog --------------------------------------------- */
QLabel#messageDialogText {
    color: #1f3a68;
    background: transparent;
    font-size: 13px;
    line-height: 140%;
}

/* -- Candidate Selection Viewport -------------------------------- */
QScrollArea#candidateScroll {
    border: 1px solid #e7eef7;
    border-radius: 4px;
    background-color: #f4f7fb;
}
QScrollArea#candidateScroll > QWidget > QWidget {
    background-color: #f4f7fb;
}

/* -- Contract label in status bar ---------------------------- */
QLabel#contractLabel {
    font-family: "Consolas", "Courier New", monospace;
    color: #0969da;
    font-size: 11px;
    background-color: transparent;
    border: none;
    padding: 0px 4px;
}