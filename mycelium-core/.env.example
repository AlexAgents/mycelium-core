# MYCELIUM CORE Environment Configuration
# Copy this file to .env and adjust values

# RPC Connection
RPC_HOST=127.0.0.1
RPC_PORT=8545

# Geth
GETH_NETWORK_ID=1337

# Transaction defaults
DEFAULT_GAS=500000
DEFAULT_GAS_PRICE=1000000000

# Solidity
SOLIDITY_VERSION=0.8.20

# Logging
LOG_LEVEL=INFO

# Dev mode (auto-fills admin key, enables mining button)
DEV_MODE=true

DEV_ADMIN_KEY=0x...